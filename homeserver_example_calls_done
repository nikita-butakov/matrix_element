server_name: "jitsidevops.website"
pid_file: /data/homeserver.pid

# TLS
tls_certificate_path: "/data/cert.pem"
tls_private_key_path: "/data/key.pem"

listeners:
  # Client API
  - port: 8008
    type: http
    tls: false
    bind_addresses: ['0.0.0.0']
    x_forwarded: true
    resources:
      - names: [client, federation]

  # Federation
  - port: 8448
    type: http
    tls: true
    bind_addresses: ['0.0.0.0']
    resources:
      - names: [federation]

turn_uris:
  - "turn:turn.jitsidevops.website:3478?transport=udp"
  - "turn:turn.jitsidevops.website:3478?transport=tcp"

turn_shared_secret: "my_personal_secret_qwerty12345"

turn_user_lifetime: 86400000
turn_allow_guests: true
database:
  name: sqlite3
  args:
    database: /data/homeserver.db
log_config: "/data/jitsidevops.website.log.config"
media_store_path: /data/media_store
